{
  "schemaVersion": 1,
  "id": "schematicautobuilder",
  "version": "${version}",
  "name": "Schematic Auto Builder",
  "description": "One-button Litematica/Schematica building helper using Baritone, registered material chests, status HUD, and a GitHub update manifest.",
  "authors": [
    "kanzakideath",
    "Codex"
  ],
  "contact": {
    "sources": "https://github.com/kanzakideath/schematic-autobuilder"
  },
  "license": "LGPL-3.0-or-later",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.kanzakideath.schematicautobuilder.SchematicAutoBuilderMod"
    ]
  },
  "mixins": [
    "schematicautobuilder.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": "26.2",
    "baritone": "*"
  },
  "suggests": {
    "litematica": "*"
  }
}
